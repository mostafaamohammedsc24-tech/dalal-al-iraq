# Local production environment
PGDATA=/home/you/.local/share/dalal_al_iraq_pgdata
PGPORT=5433
DATABASE_URL=postgresql://dalal_user:dalal_password@localhost:5433/dalal_al_iraq
SESSION_SECRET=replace_with_a_strong_random_secret
PORT=8080

# Media storage: "local" writes to disk (default), "replit" uses object storage.
STORAGE_DRIVER=local
# Directory for locally-stored uploads (images/videos/voice). Defaults to ./uploads.
LOCAL_STORAGE_DIR=./uploads

# Public site origin used to build office QR deep links + listing share links and
# server-rendered Open Graph previews (falls back to the request host).
# PUBLIC_SITE_URL=https://dalalaliraqnetwork.online
# Same origin exposed to the frontend build for share URLs (defaults to window origin).
# VITE_PUBLIC_SITE_URL=https://dalalaliraqnetwork.online

# Local AI assistant (Ollama + Qwen2.5). The model only extracts search params and
# formats Arabic replies; all searches run against PostgreSQL. No external browsing.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b-instruct
OLLAMA_TIMEOUT_MS=60000
